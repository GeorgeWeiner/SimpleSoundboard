<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SimpleSoundboard.Controls.RenameDialog"
        Title="Rename sound"
        Width="340" SizeToContent="Height"
        CanResize="False" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Surface}">

    <StackPanel Margin="18" Spacing="12">
        <TextBlock Name="LabelText" Text="Button name" Foreground="{DynamicResource Cream}"
                   FontWeight="SemiBold" />
        <TextBox Name="NameBox" Watermark="Name" />
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Classes="tool" Content="Cancel" Click="OnCancel" />
            <Button Classes="tool" Content="Save" Click="OnSave" IsDefault="True" />
        </StackPanel>
    </StackPanel>

</Window>
