<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SimpleSoundboard.Controls.HotkeyDialog"
        Title="Set hotkey"
        Width="340" SizeToContent="Height"
        CanResize="False" ShowInTaskbar="False"
        Focusable="True"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Surface}">

    <StackPanel Margin="18" Spacing="12">
        <TextBlock Text="Press a key combination" Foreground="{DynamicResource Cream}"
                   FontWeight="SemiBold" />
        <Border Background="{DynamicResource Ink}" CornerRadius="6" Padding="12" MinHeight="46">
            <TextBlock Name="GestureText" Text="Press keys…" FontSize="16"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <TextBlock Text="Needs a modifier (Ctrl/Alt/Shift) or an F-key. Esc cancels, Del clears."
                   FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Classes="tool" Content="Clear" Click="OnClear" />
            <Button Classes="tool" Content="Cancel" Click="OnCancel" />
            <Button Classes="tool" Content="Save" Click="OnSave" />
        </StackPanel>
    </StackPanel>

</Window>
