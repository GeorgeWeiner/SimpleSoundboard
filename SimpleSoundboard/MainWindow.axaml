<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:SimpleSoundboard.Models"
        xmlns:audio="clr-namespace:SimpleSoundboard.Audio"
        xmlns:controls="clr-namespace:SimpleSoundboard.Controls"
        mc:Ignorable="d"
        x:Class="SimpleSoundboard.MainWindow"
        x:DataType="models:SoundClip"
        Title="Simple Soundboard"
        Width="720" Height="500"
        MinWidth="600" MinHeight="360"
        Foreground="{StaticResource Cream}"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Panel>
        <!-- Glass background tinted with the darkest palette colour -->
        <ExperimentalAcrylicBorder IsHitTestVisible="False" CornerRadius="10">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial BackgroundSource="Digger"
                                             TintColor="#222021"
                                             TintOpacity="1"
                                             MaterialOpacity="0.62" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <!-- Subtle top-down depth gradient -->
        <Border CornerRadius="10" IsHitTestVisible="False">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#403f5d4d" Offset="0" />
                    <GradientStop Color="#00222021" Offset="0.45" />
                    <GradientStop Color="#33222021" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <DockPanel>
            <!-- Custom title bar -->
            <Grid DockPanel.Dock="Top" Height="44" Name="TitleBar" Background="Transparent"
                  ColumnDefinitions="Auto,*,Auto"
                  PointerPressed="OnTitleBarPressed" DoubleTapped="OnTitleBarDoubleTapped">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="11"
                            Margin="15,0,0,0" VerticalAlignment="Center">
                    <controls:LogoControl Width="24" Height="24" />
                    <TextBlock Text="SOUNDBOARD" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource Cream}" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Classes="chrome" Click="OnMinimize" FontFamily="Segoe Fluent Icons"
                            Content="&#xE921;" ToolTip.Tip="Minimize" />
                    <Button Classes="chrome" Click="OnMaximize" FontFamily="Segoe Fluent Icons"
                            Content="&#xE922;" ToolTip.Tip="Maximize" />
                    <Button Classes="chrome close" Click="OnClose" FontFamily="Segoe Fluent Icons"
                            Content="&#xE8BB;" ToolTip.Tip="Close" />
                </StackPanel>
            </Grid>

            <!-- Status line -->
            <Border DockPanel.Dock="Bottom" BorderBrush="#33efdebf" BorderThickness="0,1,0,0"
                    Padding="18,9">
                <TextBlock Name="StatusText" Text="Ready" Opacity="0.65" FontSize="12"
                           TextWrapping="Wrap" />
            </Border>

            <!-- Body -->
            <DockPanel Margin="16,6,16,8">
                <!-- Toolbar card -->
                <Border DockPanel.Dock="Top" Background="#592f4442" CornerRadius="12"
                        BorderBrush="#33efdebf" BorderThickness="1"
                        Padding="12,10" Margin="0,0,0,12">
                    <StackPanel Spacing="10">
                        <!-- Row 1: actions -->
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Button Classes="tool" Name="AddButton" Click="OnAddClick">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE710;"
                                               FontSize="13" VerticalAlignment="Center" />
                                    <TextBlock Text="Add sound" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Classes="tool" Name="StopButton" Click="OnStopClick">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <Rectangle Width="10" Height="10" RadiusX="2" RadiusY="2"
                                               Fill="{StaticResource Cream}" VerticalAlignment="Center" />
                                    <TextBlock Text="Stop all" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Border Width="1" Background="#33efdebf" Margin="4,3" />

                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE767;"
                                       VerticalAlignment="Center" FontSize="15" />
                            <Slider Name="VolumeSlider" Width="140" Minimum="0" Maximum="100"
                                    VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Row 2: routing -->
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <CheckBox Name="MonitorCheck" Content="Monitor" VerticalAlignment="Center"
                                      ToolTip.Tip="Also play to a device you can hear." />
                            <ComboBox Name="MonitorDeviceCombo" Width="170" VerticalAlignment="Center"
                                      ToolTip.Tip="Which device you listen on.">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="audio:OutputDevice">
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <CheckBox Name="VbCableCheck" Content="VB-Cable" VerticalAlignment="Center" />

                            <Border Width="1" Background="#33efdebf" Margin="4,3" />

                            <CheckBox Name="MicCheck" Content="Mic" VerticalAlignment="Center"
                                      Click="OnMicToggle"
                                      ToolTip.Tip="Pipe your microphone into VB-Cable alongside the sounds." />
                            <ComboBox Name="MicDeviceCombo" Width="170" VerticalAlignment="Center"
                                      SelectionChanged="OnMicDeviceChanged"
                                      ToolTip.Tip="Which microphone to route.">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="audio:OutputDevice">
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Now Playing panel -->
                <Border DockPanel.Dock="Right" Width="226" Margin="12,0,0,0"
                        Background="#592f4442" CornerRadius="12"
                        BorderBrush="#33efdebf" BorderThickness="1" Padding="12,10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="NOW PLAYING" FontWeight="Bold"
                                   FontSize="12" Opacity="0.85" Margin="2,0,2,10" />
                        <TextBlock DockPanel.Dock="Top" Name="NowPlayingEmpty"
                                   Text="Nothing playing right now." Opacity="0.4" FontSize="12"
                                   Margin="2" TextWrapping="Wrap" />
                        <ScrollViewer>
                            <ItemsControl Name="PlayingList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="audio:Playback">
                                        <Border Background="#3f5d4d" CornerRadius="8"
                                                Padding="10,8" Margin="0,0,0,8">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Classes="mini"
                                                        Click="OnStopPlayback" Width="26" Height="26"
                                                        VerticalAlignment="Top" Margin="6,0,0,0"
                                                        ToolTip.Tip="Stop">
                                                    <Rectangle Width="9" Height="9" RadiusX="2" RadiusY="2"
                                                               Fill="{StaticResource Cream}" />
                                                </Button>
                                                <StackPanel Spacing="6">
                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <TextBlock Text="&#xE8EE;"
                                                                   FontFamily="Segoe Fluent Icons"
                                                                   FontSize="11" VerticalAlignment="Center"
                                                                   Opacity="0.85"
                                                                   IsVisible="{Binding IsLooping}" />
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                   FontSize="12"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <ProgressBar Minimum="0" Maximum="1"
                                                                 Value="{Binding Progress}" Height="4"
                                                                 MinWidth="0" HorizontalAlignment="Stretch"
                                                                 CornerRadius="2" Background="#33222021"
                                                                 Foreground="{StaticResource Cream}" />
                                                    <TextBlock Text="{Binding PositionText}" FontSize="10"
                                                               Opacity="0.7" />
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Sound area: category tabs + grid -->
                <DockPanel>
                    <!-- Category tabs -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Button DockPanel.Dock="Right" Classes="tab" Click="OnAddCategory"
                                FontFamily="Segoe Fluent Icons" Content="&#xE710;"
                                ToolTip.Tip="New category" VerticalAlignment="Center" />
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl Name="CategoryTabs">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:CategoryTab">
                                        <Button Classes="tab" Classes.active="{Binding IsSelected}"
                                                Click="OnTabClick" Content="{Binding Name}">
                                            <Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Rename…" Click="OnRenameCategory"
                                                              IsVisible="{Binding !IsAll}" />
                                                    <MenuItem Header="Delete" Click="OnDeleteCategory"
                                                              IsVisible="{Binding !IsAll}" />
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>

                    <ScrollViewer>
                        <Panel>
                            <TextBlock Name="EmptyHint"
                                       Text="No sounds here — add some or drop files in."
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="0,40,0,0" Opacity="0.4" FontSize="14"
                                       IsVisible="False" />
                            <ItemsControl Name="SoundList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SoundClip">
                                    <Button Classes="sound" Click="OnPlayClick"
                                            Width="148" Height="68" Margin="6"
                                            HorizontalContentAlignment="Stretch"
                                            VerticalContentAlignment="Stretch">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Rename…" Click="OnRenameClick" />
                                                <MenuItem Header="Favorite" ToggleType="CheckBox"
                                                          IsChecked="{Binding IsFavorite, Mode=TwoWay}"
                                                          Click="OnFavoriteClick" />
                                                <MenuItem Header="Loop" ToggleType="CheckBox"
                                                          IsChecked="{Binding IsLooping, Mode=TwoWay}"
                                                          Click="OnLoopClick" />
                                                <MenuItem Header="Category…" Click="OnSetCategory" />
                                                <Separator />
                                                <MenuItem Header="Remove" Click="OnRemoveClick" />
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Panel>
                                            <TextBlock Text="{Binding Name}" TextWrapping="Wrap"
                                                       TextAlignment="Center" MaxLines="3"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="&#xE735;" FontFamily="Segoe Fluent Icons"
                                                       FontSize="12" Foreground="{StaticResource Cream}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Top"
                                                       Margin="0,-3,-3,0"
                                                       IsVisible="{Binding IsFavorite}" />
                                            <TextBlock Text="&#xE8EE;" FontFamily="Segoe Fluent Icons"
                                                       FontSize="12" Foreground="{StaticResource Cream}"
                                                       HorizontalAlignment="Left" VerticalAlignment="Top"
                                                       Margin="-3,-3,0,0" Opacity="0.85"
                                                       IsVisible="{Binding IsLooping}" />
                                        </Panel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Panel>
                    </ScrollViewer>
                </DockPanel>
            </DockPanel>
        </DockPanel>

        <!-- Drag-and-drop overlay (shown while dragging files over the window) -->
        <Border Name="DropOverlay" IsVisible="False" IsHitTestVisible="False"
                CornerRadius="10" Background="#dd222021"
                BorderBrush="{StaticResource Cream}" BorderThickness="2" Margin="6">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons" FontSize="44"
                           Foreground="{StaticResource Cream}" HorizontalAlignment="Center" />
                <TextBlock Text="Drop audio files to add" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource Cream}" HorizontalAlignment="Center" />
                <TextBlock Text="WAV · MP3 · OGG" FontSize="12" Opacity="0.6"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Panel>

</Window>
